{
  "name": "@workspace/sci-cream-app",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "install:deps": "pnpm --dir ../sci-cream install:wasm",
    "build:deps": "pnpm --dir ../sci-cream build:package",
    "build:analyze": "ANALYZE=true next build --webpack",
    "build": "next build",
    "test": "pnpm test:unit && pnpm test:e2e && pnpm test:visual",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --project chromium firefox webkit mobile-chrome mobile-safari",
    "test:e2e:chromium": "playwright test --project chromium",
    "test:e2e:ui": "pnpm test:e2e --ui",
    "test:visual": "playwright test --project visual",
    "test:visual:update": "pnpm test:visual --update-snapshots",
    "lint": "eslint ./src --max-warnings=0",
    "prettier": "prettier --check ./src",
    "coverage": "vitest run --coverage",
    "bench": "pnpm bench:unit && pnpm bench:bundle && pnpm bench:e2e && pnpm bench:web-vitals",
    "bench:unit": "node --import tsx src/__benches__/unit/run-all.ts",
    "bench:bundle": "node --import tsx src/__benches__/bundle/measure.ts",
    "bench:e2e": "playwright test --project benches --grep-invert 'Web Vitals' --reporter='dot'",
    "bench:web-vitals": "playwright test --project benches --grep 'Web Vitals' --reporter='dot'",
    "dev": "pnpm dev:turbopack",
    "dev:turbopack": "next dev --turbopack",
    "dev:webpack": "next dev --webpack",
    "start": "next start",
    "seed-db": "npx drizzle-kit push && pnpm tsx ./src/lib/database/seed.ts",
    "doc": "tsc --noEmit false --outDir ./dist && npx jsdoc -c ./jsdoc.config.json"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@workspace/sci-cream": "workspace:*",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "chartjs-chart-error-bars": "^4.4.5",
    "colord": "^2.9.3",
    "docdash": "^2.0.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "eslint-plugin-jsdoc": "^63.0.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "react-resizable": "^4.0.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest-canvas-mock": "^1.1.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/benchmark": "^2.1.5",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "benchmark": "^2.1.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-config-next": "16.2.9",
    "jsdoc": "^4.0.5",
    "jsdoc-plugin-typescript": "^3.2.1",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
