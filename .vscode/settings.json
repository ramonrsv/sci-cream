{
  "html.format.indentInnerHtml": true,
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[rust]": { "editor.defaultFormatter": "rust-lang.rust-analyzer" },
  "files.associations": {
    "*.js": "javascriptreact",
    "*.css": "tailwindcss",
    "*.scss": "tailwindcss"
  },
  "editor.formatOnSave": true,
  "evenBetterToml.schema.associations": {
    ".*Cargo\\.toml": "https://github.com/rust-lang/cargo/blob/master/crates/cargo-util-schemas/manifest.schema.json"
  },
  "rust-analyzer.linkedProjects": ["./packages/sci-cream/Cargo.toml"],
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.check.features": "all",
  "rust-analyzer.cargo.allTargets": true,
  "rust-analyzer.check.allTargets": true,
  "rust-analyzer.check.command": "clippy",
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "editor.codeActionsOnSave": { "source.fixAll.eslint": "never" },
  "prettier.printWidth": 100,
